<Window x:Class="CyberPrimeWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberPrime - Cybersecurity Awareness Chatbot" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FF0A0A0A">

    <Window.Resources>
        <!-- Styles -->
        <Style x:Key="ChatBubbleUser" TargetType="Border">
            <Setter Property="Background" Value="#FF2E7D32"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="100,5,20,5"/>
        </Style>

        <Style x:Key="ChatBubbleBot" TargetType="Border">
            <Setter Property="Background" Value="#FF1A237E"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="20,5,100,5"/>
        </Style>

        <Style x:Key="WarningBubble" TargetType="Border">
            <Setter Property="Background" Value="#FFB71C1C"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="20,5,100,5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1A237E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF283593"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FF00FF00"/>
            <Setter Property="BorderBrush" Value="#FF00FF00"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#FF0A0A0A"/>
            <Setter Property="Foreground" Value="#FF00FF00"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art -->
        <Border Grid.Row="0" Background="#FF0D1B2A" Padding="10">
            <StackPanel>
                <TextBlock x:Name="AsciiArt" FontFamily="Consolas" FontSize="10" 
                           Foreground="#FF00FF00" TextAlignment="Center" 
                           Text="Loading..." Height="80"/>
                <TextBlock Text="Cybersecurity Awareness Chatbot" 
                           FontSize="18" FontWeight="Bold" 
                           Foreground="#FF00FF00" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <ListBox x:Name="ChatListBox" Grid.Row="1" Margin="10" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="#FF0A0A0A" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{Binding Style}" Margin="{Binding Margin}">
                        <StackPanel>
                            <TextBlock Text="{Binding Sender}" FontWeight="Bold" 
                                       Foreground="#FF888888" FontSize="10"/>
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" 
                                       Foreground="{Binding Foreground}" 
                                       FontSize="13" FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding Timestamp}" FontSize="9" 
                                       Foreground="#FF666666" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#FF1A1A1A" Padding="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Text="Connected" Foreground="#FF00FF00" 
                           FontSize="11" Margin="5"/>
                <TextBlock x:Name="UserInfo" Text="" Foreground="#FF00AAFF" 
                           FontSize="11" Margin="20,5,5,5"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="3" Background="#FF1A1A1A" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox" Grid.Column="0" 
                         Height="60" VerticalContentAlignment="Top"
                         KeyDown="InputTextBox_KeyDown"
                         TextWrapping="Wrap" AcceptsReturn="True"/>

                <Button x:Name="SendButton" Grid.Column="1" Content="Send" 
                        Width="80" Height="60" Click="SendButton_Click"
                        FontSize="14"/>

                <Button x:Name="VoiceButton" Grid.Column="2" Content="🎤" 
                        Width="60" Height="60" Click="VoiceButton_Click"
                        FontSize="20"/>
            </Grid>
        </Border>
    </Grid>
</Window>